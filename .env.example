# Copia este archivo: cp .env.example .env
# Rellena los valores y NO compartas el .env con nadie

# Tu API key de DeepSeek (platform.deepseek.com)
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# El username de tu bot de Telegram (sin la @)
# Ejemplo: si tu bot es @mis_recetas_bot, pon: mis_recetas_bot
BOT_USERNAME=nombre_de_tu_bot
